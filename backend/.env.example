# ==========================================
# DHsystem MCP Backend - Configuration
# ==========================================
# Copy file này sang .env và điền thông tin thực

# --- Appwrite Cloud (REQUIRED) ---
# Lấy tại: cloud.appwrite.io -> Project -> Settings
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your-project-id-here
APPWRITE_API_KEY=your-api-key-here

# Tên Database và Collections (tự động tạo khi chạy lần đầu)
APPWRITE_DATABASE_ID=dhsystem_db
APPWRITE_KB_COLLECTION_ID=knowledge_bases
APPWRITE_DOC_COLLECTION_ID=documents

# --- Google Gemini AI (REQUIRED) ---
# Lấy tại: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# --- ChromaDB (Vector Store - chạy local, không cần cấu hình) ---
# Thư mục lưu vector database (tự động tạo)
CHROMA_PERSIST_DIR=./chroma_data

# --- Server Settings ---
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8000
MCP_SERVER_NAME=dhsystem-knowledge-hub

# WebSocket Bridge cho ESP32-S3
WS_SERVER_PORT=8765

# --- Security (tùy chọn) ---
API_SECRET_TOKEN=

# --- Xiaozhi MCP Pipe (kết nối Xiaozhi.me cloud) ---
# Lấy WSS URL tại: xiaozhi.me → Console → Tạo MCP connection
# Video hướng dẫn: https://youtu.be/1yIDnwCz0k4
MCP_ENDPOINT=wss://your-xiaozhi-wss-url-here

